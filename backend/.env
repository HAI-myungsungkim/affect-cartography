# Database
DATABASE_URL=postgresql+asyncpg://affect_user:affect_pass@localhost:5432/affect_cartography
DATABASE_URL_SYNC=postgresql://affect_user:affect_pass@localhost:5432/affect_cartography

# JWT
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=43200

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_ZERO_DATA_RETENTION=true

# Admin
ADMIN_CODE=change-me
ADMIN_CODE_SALT=change-me-salt

# Redis (for notification scheduling)
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
APP_DEBUG=true
APP_NAME=Affect Cartography API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8080

# Safety
CRISIS_HOTLINE=1393
KAIST_COUNSELING=042-350-2181
